# Select which env file to load (optional when using ".env")
ENV_FILE=.env

# Database config
DB_PATH=data/app.db
MYSQL_ENABLED=false
MYSQL_CONNECTION_STRING=mysql://remoteuser:StrongPassword@127.0.0.1:3306/myapp

# Image server URL used in payload links
IMAGE_SERVER_URL=http://127.0.0.1:3000
TAG_SESSION_TIMEOUT_SECONDS=10

# Stations config as JSON (preferred)
STATIONS_JSON='[{"id":1,"name":"bascol_1","type":"bascol","TAG_SESSION_TIMEOUT_SECONDS":30,"primary_cameras":[{"id":1,"host":"192.168.1.95"},{"id":5,"host":"192.168.1.96"}],"secondary_cameras":[{"id":2,"host":"192.168.1.205"}],"rfid_devices":[{"id":3,"host":"192.168.1.10","port":6000},{"id":4,"host":"192.168.1.11","port":6000}]}]'

# Advanced config overrides for DEFAULT_CONFIG using CFG__<section>__<key>
# Examples:
# CFG__OCR__MODEL_ID=./trocr-large-printed
# CFG__OCR__DEVICE=cuda
# CFG__CAPTURE__TIMEOUT_SECONDS=30
# CFG__CAPTURE__MAX_ATTEMPTS=10
# CFG__RFID__DEBOUNCE_SECONDS=1.0
# CFG__RFID__PRESENT_WINDOW_SECONDS=2.0
# CFG__PAPER_DETECTION__MASK_PATH=Mask.png
# CFG__CAMERA__USERNAME=admin
# CFG__CAMERA__PASSWORD=
# CFG__SECONDARY_CAMERA__USERNAME=admin
# CFG__SECONDARY_CAMERA__PASSWORD=
