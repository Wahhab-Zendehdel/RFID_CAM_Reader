# Use this file for container deployments.
ENV_FILE=.env.docker

# Database config in container volume
DB_PATH=/app/data/app.db
MYSQL_ENABLED=false
MYSQL_CONNECTION_STRING=mysql://remoteuser:StrongPassword@mysql:3306/myapp

# Internal service URL when image server runs in another container
IMAGE_SERVER_URL=http://image-server:3000
TAG_SESSION_TIMEOUT_SECONDS=10

# Set your actual station and device addresses reachable from container network
STATIONS_JSON='[{"id":1,"name":"bascol_1","type":"bascol","TAG_SESSION_TIMEOUT_SECONDS":30,"primary_cameras":[{"id":1,"host":"192.168.1.95"},{"id":5,"host":"192.168.1.96"}],"secondary_cameras":[{"id":2,"host":"192.168.1.205"}],"rfid_devices":[{"id":3,"host":"192.168.1.10","port":6000},{"id":4,"host":"192.168.1.11","port":6000}]}]'

# Optional advanced overrides
# CFG__OCR__MODEL_ID=./trocr-large-printed
# CFG__OCR__DEVICE=cpu
# CFG__CAPTURE__TIMEOUT_SECONDS=30
# CFG__CAPTURE__MAX_ATTEMPTS=10
